{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "البيان",
  "scopeName": "source.bayan",
  "patterns": [
    { "include": "#baligh-verbs" },
    { "include": "#good-verbs" },
    { "include": "#normal-verbs" },
    { "include": "#strings" },
    { "include": "#comments" },
    { "include": "#numbers" },
    { "include": "#basmala" }
  ],
  "repository": {
    "basmala": {
      "name": "keyword.control.basmala.bayan",
      "match": "بِسْمِ اللَّهِ",
      "patterns": [{ "name": "entity.name.type.gold.bayan" }]
    },
    "baligh-verbs": {
      "name": "entity.name.function.baligh.bayan",
      "match": "\\b(اِستَحفَظَ|اِستَقرَأَ|اِستَعلَمَ|اِستَكتَبَ|اِستَحسَبَ)\\b"
    },
    "good-verbs": {
      "name": "entity.name.function.good.bayan",
      "match": "\\b(حَسَّبَ|حَاسَبَ|بَاعَثَ|قَارَأَ|حَافَظَ)\\b"
    },
    "normal-verbs": {
      "name": "entity.name.function.normal.bayan",
      "match": "\\b(قَرَأَ|كَتَبَ|حَسَبَ|حَفِظَ|بَعَثَ|جَمَعَ|فَصَلَ|رَسَمَ|عَلِمَ)\\b"
    },
    "strings": {
      "name": "string.quoted.double.bayan",
      "begin": "\"", "end": "\""
    },
    "comments": {
      "name": "comment.line.double-slash.bayan",
      "match": "//.*$"
    },
    "numbers": {
      "name": "constant.numeric.bayan",
      "match": "\\b\\d+(\\.\\d+)?\\b"
    }
  }
}
