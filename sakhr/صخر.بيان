// تعريف المهمة
دالة مهمة(اسم، حالة) = خزن اسم في حالة

// إضافة مهمة جديدة
دالة أضف(اسم) = مهمة اسم "نشطة"

// إكمال مهمة
دالة أكمل(اسم) = مهمة اسم "مكتملة"

// حذف مهمة
دالة احذف(اسم) = مهمة اسم "محذوفة"

// عرض المهام
دالة اعرض() = اِحتَسَبَ

// بحث عن مهمة
دالة ابحث(اسم) = استرجع اسم

// إحصاء المهام
دالة أحصي() = عد المهام

// تصدير التقرير
دالة صدر(ملف) = اِكتُب ملف التقرير

// بداية البرنامج
أضف "مشروع البيان"
أضف "توثيق اللغة"
أضف "نشر التطبيق"
أكمل "توثيق اللغة"
