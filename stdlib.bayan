// ============================================
// المكتبة القياسية للغة البيان
// ============================================

// -- الإدخال والإخراج --
دالة اِقرَأ(ملف) = قَرَأَ ملف
دالة اِكتُب(ملف، محتوى) = كَتَبَ ملف محتوى
دالة اِطبَع(نص) = أَظهِر نص

// -- الحساب --
دالة اِحسِب(بيانات) = حَسَبَ بيانات
دالة اِحسِب_بالتوازي(بيانات) = حَسَّبَ بيانات

// -- الأمان --
دالة شفِّر(بيانات) = حَفِظَ بيانات
دالة اِفحَص(نظام) = اِحتَسَبَ نظام

// -- الشبكة --
دالة اِرسِل(بيانات، عنوان) = بَعَثَ بيانات عنوان
دالة اِستَقبِل(منفذ) = اِنبَعَثَ منفذ

// -- المتغيرات --
دالة اِجعَل(اسم، قيمة) = اجعل اسم في قيمة
دالة اِستَرجِع(اسم) = استرجع اسم

// -- المنطق --
دالة اِذا(شرط، نتيجة) = إذا شرط فـ نتيجة
دالة كَرِّر(فعل، عدد) = كرر فعل عدد مرات
